# ============================================================================
#  Audiobook Bot — configuration
#  Copy this file to ".env" and fill in real values. NEVER commit ".env".
# ============================================================================

# --- Telegram ---------------------------------------------------------------
# Token issued by @BotFather. KEEP SECRET. If it ever leaks, revoke & reissue
# with /revoke in @BotFather.
BOT_TOKEN=000000000:AA-replace-with-your-token

# Telegram user IDs allowed into the (future) admin panel. Comma-separated.
# Find your id via @userinfobot. The admin panel itself is not built yet,
# but the architecture is already gated on this list.
ADMIN_IDS=

# --- Branding / UX ----------------------------------------------------------
# Shown in the signature footer that travels with every forwarded message.
BRAND_NAME=Audiobook Library
DEFAULT_LANGUAGE=ru          # ru | en  (fallback language for UI strings)

# --- Storage ----------------------------------------------------------------
# Async SQLAlchemy URL. SQLite is perfect for this workload.
# To migrate to Postgres later: postgresql+asyncpg://user:pass@host/db
DATABASE_URL=sqlite+aiosqlite:///data/bot.db

# --- Behaviour flags --------------------------------------------------------
# Bot API 10.1 "Rich Messages" (sendRichMessage). Released 2026-06-11; library
# wrappers are still maturing and the parameter schema is not fully published.
# Leave FALSE to use the fully-supported rich entities (expandable blockquote,
# spoiler, custom emoji). Flip to TRUE once you have confirmed the live schema.
USE_RICH_MESSAGES=false

# If TRUE, recipients cannot forward/save content (NOT what we want here — the
# whole point is shareable chapters with a signature). Leave FALSE.
PROTECT_CONTENT=false

# Drop updates that piled up while the bot was offline (recommended on deploy).
DROP_PENDING_UPDATES=true

# --- Logging ----------------------------------------------------------------
LOG_LEVEL=INFO
